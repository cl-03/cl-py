(:id "jsonschema"
 :manifest-version "1.0"
 :name "jsonschema"
 :upstream-url "https://github.com/python-jsonschema/jsonschema"
 :license "MIT"
 :python-module "jsonschema"
 :python-distribution "jsonschema"
 :python-requirement "jsonschema>=4.0,<5.0"
 :capabilities ("metadata" "version" "validate-instance")
 :summary "JSON Schema validation via jsonschema.validate")